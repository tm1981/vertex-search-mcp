# Required: Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Required: Path to your service account JSON key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# The service account needs the "Vertex AI User" role
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Optional: Google Cloud region (defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: The Gemini model to use (defaults to gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: Custom system instruction for the model
# MODEL_SYSTEM_INSTRUCTION=Your custom instructions here

# Optional: Set a port to run as an HTTP Streamable HTTP background service
# If omitted, the server runs via Standard I/O (stdio)
# PORT=3000

# Optional: AI generation tuning (defaults shown)
# MAX_OUTPUT_TOKENS=30090
# TEMPERATURE=1
# TOP_P=0.95
# MAX_RETRIES=3
